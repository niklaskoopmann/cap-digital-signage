# ==============================
# Xibo Media Sync - Configuration
# Location: main/scripts/.env
# ==============================

# ---- WiFi / Hotspot ----
# SSID broadcast by the air-gapped Xibo machine hotspot
WIFI_SSID=XIBO-HOTSPOT

# Windows WLAN profile name.
# If the user never connected before, the script will create/import a WLAN profile with this name.
# Usually you can keep it identical to the SSID.
WIFI_PROFILE=XIBO-HOTSPOT

# Hotspot password (stored in plain text in this .env).
# If WIFI_AUTH=open, this can be empty.
WIFI_PASSWORD=password123

# WiFi security settings.
# Typical Ubuntu hotspot: WPA2PSK + AES.
# Allowed WIFI_AUTH: WPA2PSK | WPAPSK | open
WIFI_AUTH=WPA2PSK
# Allowed WIFI_CIPHER: AES | TKIP
WIFI_CIPHER=AES

# How long the script should wait for the WiFi connection.
WIFI_CONNECT_TIMEOUT_SECONDS=30


# ---- Xibo CMS ----
# Your Xibo CMS base URL on the hotspot network.
CMS_BASE_URL=http://localhost

# If you use HTTPS with valid certificates, you can set this to true.
CMS_VERIFY_TLS=false

# HTTP timeout (seconds) for API calls
CMS_TIMEOUT_SECONDS=30


# ---- API Auth ----
# none  -> do not send any Authorization header (works only if API auth is disabled)
# oauth -> uses OAuth2 Client Credentials against /api/authorize/access_token
AUTH_MODE=oauth

# OAuth application credentials (Administration > Applications in Xibo CMS)
# WARNING: stored in plain text.
CMS_CLIENT_ID=client_id_here
CMS_CLIENT_SECRET=client_secret_here


# ---- Local media ----
# Path to your local media directory.
# Recommended: relative to scripts/ so the whole folder can be moved.
LOCAL_MEDIA_DIR=../media

# File extensions to consider as media.
MEDIA_EXTENSIONS=.jpg,.jpeg,.png,.gif,.mp4,.mov,.mkv,.webm

# Compare mode:
# filename -> compares local filename vs Xibo media name
# hash     -> compares sha256 hashes stored as tags in Xibo (requires the script to have uploaded/tagged the files before)
COMPARE_MODE=filename


# ---- Safety scope (recommended) ----
# Tag used to mark media managed by this sync script.
MANAGED_TAG=xibo-sync

# Only delete remote media that has MANAGED_TAG.
# Strongly recommended to prevent deleting unrelated CMS library items.
ONLY_DELETE_MANAGED_TAG=true

# Optional: restrict sync to a CMS folder ID (leave empty to ignore)
MANAGED_FOLDER_ID=


# ---- Behavior ----
# Upload new local files
UPLOAD_NEW_LOCAL=true

# Delete remote files that are missing locally
# This will also be asked at runtime (you can override per run).
DELETE_REMOTE_NOT_LOCAL=true

# Dry run -> do not upload/delete, only show what would happen
DRY_RUN=false


# ---- Player refresh ----
# Optional: trigger Collect Now after changes.
# If empty, refresh is skipped.
DISPLAY_GROUP_ID=
TRIGGER_COLLECTNOW_ON_CHANGES=true


# ---- Hash tagging ----
HASH_TAG_PREFIX=sha256:


# ---- Upload ----
# Multipart field name for upload. Some versions differ; script tries fallbacks automatically.
XIBO_UPLOAD_FIELD=files


# ---- Logging ----
LOG_LEVEL=INFO
# Optional: write logs to a file (relative to scripts/). Leave empty to disable.
LOG_FILE=logs/sync_xibo.log
